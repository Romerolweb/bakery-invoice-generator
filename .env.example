# Environment Variables Template
# Copy this file to .env.dev or .env.prod and modify as needed

# Server Configuration
PORT=9002                    # Server port (9002 for dev, 3000 for prod)
NODE_ENV=development         # Environment mode (development/production)

# Debug (optional)
# DEBUG=FALSE                   # Enable debug logging (uncomment for verbose logs)

# Database (PostgreSQL)
DATABASE_URL=postgres://bakery:bakery@localhost:5432/bakery  # PostgreSQL connection string

# API Keys
# API_KEY=                  # External API key
# SECRET_KEY=               # Application secret key

GEMINI_API_KEY=              # Gemini API key for AI services
